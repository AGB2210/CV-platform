# Normalize line endings.
#
# Without this, Git on Windows converts LF->CRLF on checkout and back on commit,
# which produces the "LF will be replaced by CRLF" warnings and can show whole
# files as modified when a collaborator (or WSL, or a Docker build) touches them.
# `text=auto eol=lf` stores everything as LF in the repo — the portable choice.
* text=auto eol=lf

# Windows-only scripts must keep CRLF or cmd.exe misparses them.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files: never munge these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pt binary
*.pth binary
*.onnx binary
*.safetensors binary
*.db binary
