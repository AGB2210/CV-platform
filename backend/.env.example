# Copy to `.env` and edit as needed. Every value here has a working default in
# app/config.py, so a .env file is entirely optional for local development.
#
# .env is gitignored; this .example file is committed so the available knobs are
# discoverable without reading the config source.

# Flip to False to disable debug behaviour.
# DEBUG=True

# Where images, weights, and training runs are written. Point this at a
# different drive if your system disk is small — datasets and checkpoints grow
# fast.
# STORAGE_DIR=C:/cv-platform-storage

# SQLAlchemy connection URL. Swap for a Postgres URL if this ever outgrows
# SQLite (e.g. postgresql+psycopg://user:pass@localhost/cvplatform).
# DATABASE_URL=sqlite:///./cvplatform.db
